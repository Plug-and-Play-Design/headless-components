{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@org/ui/untitledui": ["./untitledui/index.ts"],
      "@org/ui/untitledui/*": ["./untitledui/*"],
      "@org/utils": ["./utils.ts"],
      "storybook/test": ["./node_modules/@storybook/test/dist/index.d.ts"]
    }
  },
  "include": ["components", "untitledui", "utils.ts", "types.d.ts", ".storybook"],
  "exclude": ["**/payload-config.ts", "node_modules"]
}
